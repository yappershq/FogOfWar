{
  "enabled": true,
  "updateIntervalMs": 15,
  // Off-thread matrix parallelism. 1 = serial. On a busy 32–64 player server raise this (e.g. 3–4) to cut matrix
  // latency — receiver rows compute in parallel, result unchanged. Clamped to CPU count; keep MODEST on a box that
  // hosts many servers. Only the OFF-thread worker is affected; the game thread's per-tick cost is unchanged.
  "maxComputeThreads": 4,
  // Peek-prediction lookahead is now PER-CLIENT and latency-aware: effective = clamp(minLookaheadMs + ping*
  // rttLookaheadScale, 0, maxLookaheadMs). Real per-client ping (m_iPing) drives the RTT term, so a high-ping
  // peeker leads further (matches what that client sees). minLookaheadMs = the 0-ping base (covers worker cadence).
  "minLookaheadMs": 180,
  "maxLookaheadMs": 375,
  "rttLookaheadScale": 1.5,
  // Only used while a client's ping is still 0 (mid-connect); real ping is used once it populates.
  "assumedRttMs": 60,
  // RTT-scaled lateral shoulder-peek origins: offset = clamp(ping*shoulderRttScale, shoulderBaseUnits,
  // maxShoulderUnits). Every observer gets a static +-shoulderBaseUnits peek even at 0 ping; set base 0 to disable.
  "shoulderBaseUnits": 24,
  "shoulderRttScale": 0.64,
  "maxShoulderUnits": 128,
  "peekMarginUnits": 21,
  "visibilityHoldMs": 150,
  "maxPredictionSpeed": 500,
  "staleVisibleMs": 250,
  "hideWeapons": true,
  "transmitChannel": 3,
  "debugStatus": false,
  "extraSeeThroughProps": [],
  "filterTeammates": false,
  // OPT-IN-WITHIN-OPT-IN: smoke raw-reads CS2 process memory via the fixed offsets below and is the only
  // non-fail-open feature. Ships DISABLED. Enable per CS2 build ONLY after re-verifying smokeOffsets, and pin
  // smokeBinarySizeBytes / smokeBinaryCrc32 so a later build change auto-disables smoke instead of using stale offsets.
  "smokeOcclusion": false,
  // Re-copy the smoke density grid at most once every N game frames while smoke is active (1 = every frame).
  "smokeCaptureIntervalFrames": 3,
  // Expected libserver.so size / CRC-32 (hex) the offsets were verified against. 0 / "" = unset (smoke allowed but
  // logs a loud "unverified" warning). When set and the loaded binary differs, smoke is disabled at Install.
  "smokeBinarySizeBytes": 0,
  "smokeBinaryCrc32": "",
  "heClearRadiusUnits": 100,
  "heClearSeconds": 2.5,
  "smokeOffsets": {
    "volume": 3504,
    "center": 212,
    "startTime": 12,
    "storage": 112,
    "frame": 236,
    "storageMask": 8,
    "storageDensity": 12296,
    "storageFrameStride": 524288,
    "storageCellStride": 16
  }
}
